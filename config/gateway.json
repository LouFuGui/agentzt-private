{
  "port": 8700,
  "issuer": "agentzt-gateway",
  "tokenTtlSeconds": 300,
  "assertionMaxAgeSeconds": 60,
  "vault": {
    "_comment": "Vault integration for secure secrets management. Set enabled=true to use Vault for API keys and tool credentials. Supports token, AppRole, and Kubernetes auth methods.",
    "enabled": false,
    "server": {
      "address": "http://localhost:8200",
      "tls": {
        "skip_verify": false
      }
    },
    "auth": {
      "_comment": "method: token (dev), approle (prod), kubernetes (cloud-native)",
      "method": "token",
      "token": ""
    },
    "autoRenew": {
      "enabled": true,
      "intervalMs": 3600000
    },
    "cache": {
      "enabled": true,
      "ttlMs": 300000
    },
    "failOpen": false,
    "timeoutMs": 5000
  },
  "upstream": {
    "_comment": "mode=mock returns a synthetic response so the demo runs fully offline. mode=passthrough routes by model to Anthropic or DeepSeek-compatible providers using enterprise keys held by the gateway.",
    "mode": "mock",
    "anthropicBaseUrl": "https://api.anthropic.com",
    "apiKeyEnv": "AGENTZT_UPSTREAM_ANTHROPIC_KEY",
    "defaultProvider": "anthropic",
    "providers": {
      "anthropic": {
        "type": "anthropic",
        "baseUrl": "https://api.anthropic.com",
        "apiKeyEnv": "AGENTZT_UPSTREAM_ANTHROPIC_KEY"
      },
      "deepseek": {
        "type": "deepseek",
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKeyEnv": "AGENTZT_UPSTREAM_DEEPSEEK_KEY",
        "defaultModel": "deepseek-chat"
      }
    },
    "routes": [
      { "pattern": "deepseek-*", "provider": "deepseek", "priority": 10 },
      { "pattern": "claude-*", "provider": "anthropic", "priority": 20 },
      { "pattern": "*", "provider": "anthropic", "priority": 99 }
    ]
  },
  "guardrails": {
    "_comment": "provider=auto uses OpenGuardrails (context-aware detection incl. indirect prompt injection) when OPENGUARDRAILS_API_KEY is set, else the local regex detector so the demo runs offline.",
    "provider": "auto",
    "input": { "mode": "block" },
    "output": { "redactSecrets": true, "check": true },
    "openguardrails": {
      "baseUrl": "https://api.openguardrails.com/v1",
      "apiKeyEnv": "OPENGUARDRAILS_API_KEY",
      "model": "OpenGuardrails-Text",
      "timeoutMs": 5000,
      "failOpen": false
    }
  },
  "opa": {
    "_comment": "Optional Open Policy Agent sidecar integration. When enabled (or AGENTZT_OPA=1), the gateway POSTs {input} to /v1/data/{policyPath}. OPA can only add an extra deny after local deny-by-default RBAC/JIT and ABAC pass.",
    "enabled": false,
    "baseUrl": "http://localhost:8181",
    "policyPath": "agentzt/authz/decision",
    "timeoutMs": 1000,
    "failOpen": false
  },
  "signoz": {
    "_comment": "Optional SigNoz OTLP/HTTP telemetry. Enable with enabled=true or AGENTZT_SIGNOZ=1. Self-hosted default endpoint is http://localhost:4318; set SIGNOZ_INGESTION_KEY for SigNoz Cloud.",
    "enabled": false,
    "endpoint": "http://localhost:4318",
    "serviceName": "agentzt-gateway",
    "ingestionKeyEnv": "SIGNOZ_INGESTION_KEY",
    "timeoutMs": 3000,
    "exportIntervalMs": 0
  },
  "tls": {
    "_comment": "Mutual TLS, opt-in (disabled by default so the zero-setup HTTP demo works). Run `agentzt tls init` to create the CA + server cert, then set enabled=true (or start the gateway with AGENTZT_TLS=1).",
    "enabled": false,
    "keyFile": ".agentzt/tls/server.key",
    "certFile": ".agentzt/tls/server.crt",
    "caFile": ".agentzt/tls/ca.crt",
    "channelBinding": true
  },
  "sandbox": {
    "_comment": "Sandbox runtime for agent tool execution. runtime=docker uses the local Docker Engine API over dockerSocketPath; runtime=aiosandbox|opensandbox|http calls baseUrl+executePath through the HTTP adapter.",
    "enabled": true,
    "runtime": "docker",
    "baseUrl": "http://localhost:8080",
    "healthPath": "/v1/sandbox/health",
    "executePath": "/v1/sandbox/execute",
    "agentPath": "/v1/sandbox/agents",
    "autoStart": true,
    "dockerSocketPath": "/var/run/docker.sock",
    "dockerApiVersion": "v1.41",
    "defaultImage": "alpine:3.20",
    "images": {
      "python": "python:3.11-slim",
      "javascript": "node:22-alpine",
      "bash": "bash:5.2"
    },
    "timeoutMs": 30000,
    "maxTimeoutMs": 60000,
    "memoryMb": 256,
    "maxMemoryMb": 512,
    "networkAccess": false,
    "filesystemAccess": [],
    "scheduling": {
      "policy": "capacity"
    },
    "runtimes": [
      {
        "name": "local-docker",
        "type": "docker",
        "enabled": true,
        "capacity": 1,
        "priority": 1,
        "defaultImage": "alpine:3.20",
        "allowedTenantIds": ["default"],
        "allowedProjectIds": ["agentzt"],
        "resources": ["sandbox.execute", "sandbox.shell", "sandbox.file.read", "sandbox.file.write", "sandbox.jupyter.execute", "agent.process"],
        "capabilities": ["sandbox.execute", "sandbox.shell", "sandbox.file.read", "sandbox.file.write", "sandbox.jupyter.execute", "agent.process"],
        "capabilityDeclarations": [
          { "name": "sandbox.execute", "kind": "execute", "longTasks": false, "sessionReuse": false, "artifacts": false },
          { "name": "agent.process", "kind": "agent", "longTasks": true, "sessionReuse": true, "artifacts": false }
        ],
        "orchestration": { "longTasks": true, "sessionReuse": true, "artifacts": false, "browser": false, "jupyter": true, "mcp": false },
        "networkPolicy": { "defaultAccess": false, "egress": [] },
        "filesystemPolicy": { "mounts": [], "readonly": true }
      },
      {
        "name": "aiosandbox-http",
        "type": "aiosandbox",
        "enabled": false,
        "baseUrl": "http://localhost:8080",
        "healthPath": "/healthz",
        "executePath": "/v1/shell/exec",
        "apiKeyEnv": "SANDBOX_API_KEY",
        "capacity": 10,
        "priority": 5,
        "resources": ["sandbox.execute", "sandbox.shell", "sandbox.file.read", "sandbox.file.write", "sandbox.jupyter.execute", "sandbox.browser", "sandbox.mcp"],
        "capabilities": ["sandbox.execute", "sandbox.shell", "sandbox.file.read", "sandbox.file.write", "sandbox.jupyter.execute", "sandbox.browser", "sandbox.mcp"],
        "capabilityDeclarations": [
          { "name": "sandbox.execute", "kind": "execute", "longTasks": true, "sessionReuse": true, "artifacts": true },
          { "name": "sandbox.jupyter.execute", "kind": "jupyter", "longTasks": true, "sessionReuse": true, "artifacts": true },
          { "name": "sandbox.browser", "kind": "browser", "longTasks": true, "sessionReuse": true, "artifacts": true },
          { "name": "sandbox.mcp", "kind": "mcp", "longTasks": true, "sessionReuse": true, "artifacts": true }
        ],
        "orchestration": { "longTasks": true, "sessionReuse": true, "artifacts": true, "browser": true, "jupyter": true, "mcp": true }
      },
      {
        "name": "opensandbox-http",
        "type": "opensandbox",
        "enabled": false,
        "baseUrl": "http://localhost:8081",
        "healthPath": "/v1/health",
        "agentPath": "/v1/sandboxes",
        "apiKeyEnv": "OPEN_SANDBOX_API_KEY",
        "capacity": 10,
        "priority": 10,
        "resources": ["agent.process", "sandbox.execute", "sandbox.shell", "sandbox.file.read", "sandbox.file.write", "sandbox.jupyter.execute"],
        "capabilities": ["agent.process", "sandbox.execute", "sandbox.shell", "sandbox.file.read", "sandbox.file.write", "sandbox.jupyter.execute"],
        "capabilityDeclarations": [
          { "name": "agent.process", "kind": "agent", "longTasks": true, "sessionReuse": true, "artifacts": true },
          { "name": "sandbox.execute", "kind": "execute", "longTasks": true, "sessionReuse": true, "artifacts": true },
          { "name": "sandbox.jupyter.execute", "kind": "jupyter", "longTasks": true, "sessionReuse": true, "artifacts": true }
        ],
        "orchestration": { "longTasks": true, "sessionReuse": true, "artifacts": true, "browser": false, "jupyter": true, "mcp": false }
      }
    ],
    "modelValidation": {
      "enabled": false,
      "highRiskOnly": true,
      "timeoutMs": 5000,
      "memoryMb": 64,
      "networkAccess": false,
      "highRiskPatterns": ["\\brm\\s+-rf", "\\bcurl\\s+", "\\bwget\\s+", "\\bchmod\\s+", "\\bssh\\s+", "\\bscp\\s+"]
    },
    "policy": {
      "allowedCommands": ["echo", "cat", "ls", "pwd"],
      "allowedLanguages": ["python", "javascript", "bash"],
      "maxTimeoutMs": 60000,
      "maxMemoryMb": 512,
      "allowNetworkAccess": false
    }
  },
  "temporal": {
    "_comment": "Temporal REST API integration for durable workflows. Agents can call temporal.workflow.start|signal|query only when RBAC explicitly grants those tools. apiKeyEnv is read only by the gateway.",
    "enabled": false,
    "baseUrl": "http://localhost:7243/api/v1",
    "namespace": "default",
    "defaultTaskQueue": "agentzt-tasks",
    "timeoutMs": 5000,
    "apiKeyEnv": "TEMPORAL_API_KEY"
  },
  "falco": {
    "_comment": "Optional Falco runtime security integration. Point Falco/Falcosidekick HTTP output at webhookPath. Alerts at or above minimumPriority deny matching agents for denyWindowSeconds.",
    "enabled": false,
    "webhookPath": "/v1/falco/events",
    "sharedSecretEnv": "AGENTZT_FALCO_SECRET",
    "minimumPriority": "warning",
    "denyWindowSeconds": 300,
    "maxEvents": 1000,
    "agentIdFields": ["agentzt.agent_id", "container.name", "k8s.pod.name"]
  }
}
